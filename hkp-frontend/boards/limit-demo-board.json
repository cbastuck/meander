{
  "boardName": "Limit Demo",
  "runtimes": [
    {
      "id": "ui",
      "name": "Browser",
      "type": "browser",
      "state": { "wrapServices": false }
    }
  ],
  "services": {
    "ui": [
      {
        "uuid": "timer-svc",
        "serviceId": "hookup.to/service/timer",
        "serviceName": "Timer",
        "state": {
          "periodic": true,
          "periodicValue": 800,
          "periodicUnit": "ms",
          "running": true,
          "start": true,
          "immediate": true
        }
      },
      {
        "uuid": "range-svc",
        "serviceId": "hookup.to/service/map",
        "serviceName": "Growing Range",
        "state": {
          "template": { "=": "range((params.triggerCount % 12) + 1)" }
        }
      },
      {
        "uuid": "limit-svc",
        "serviceId": "hookup.to/service/limit",
        "serviceName": "Limit",
        "state": { "n": 5 }
      },
      {
        "uuid": "circles-svc",
        "serviceId": "hookup.to/service/map",
        "serviceName": "To Circles",
        "state": {
          "template": {
            "type": "circle",
            "x=": "params * 90 + 80",
            "y": 200,
            "radius": 28,
            "color": "#6366f1"
          }
        }
      },
      {
        "uuid": "canvas-svc",
        "serviceId": "hookup.to/service/canvas",
        "serviceName": "Canvas",
        "state": {
          "clearOnRedraw": true,
          "resizable": true,
          "size": [600, 400]
        }
      }
    ]
  }
}
