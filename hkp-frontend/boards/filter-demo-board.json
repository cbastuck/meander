{
  "boardName": "Filter Demo",
  "runtimes": [
    {
      "id": "ui",
      "name": "Browser",
      "type": "browser",
      "state": {
        "wrapServices": false
      }
    }
  ],
  "services": {
    "ui": [
      {
        "uuid": "timer-svc",
        "serviceId": "hookup.to/service/timer",
        "serviceName": "Timer",
        "state": {
          "periodic": true,
          "periodicValue": 400,
          "periodicUnit": "ms",
          "running": true,
          "start": true,
          "immediate": true
        }
      },
      {
        "uuid": "random-svc",
        "serviceId": "hookup.to/service/map",
        "serviceName": "Random 0\u2013100",
        "state": {
          "template": {
            "=": "round(rand() * 100)"
          }
        }
      },
      {
        "uuid": "filter-svc",
        "serviceId": "hookup.to/service/filter",
        "serviceName": "Filter",
        "state": {
          "conditions": [
            "params > 50"
          ]
        }
      },
      {
        "uuid": "monitor-svc",
        "serviceId": "hookup.to/service/monitor",
        "serviceName": "Monitor"
      }
    ]
  }
}
