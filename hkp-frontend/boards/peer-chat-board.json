{
  "boardName": "Peer Chat",
  "facade": {
    "layout": "single",
    "panels": [
      {
        "id": "chat",
        "layout": {
          "type": "message-list",
          "grow": true,
          "source": { "serviceUuid": "chat-monitor-svc" },
          "composer": {
            "placeholder": "Type a message…",
            "submitLabel": "Send",
            "action": {
              "serviceUuid": "chat-input-svc",
              "configure": { "inject": "$$input" }
            }
          }
        }
      }
    ]
  },
  "runtimes": [
    {
      "id": "chat-browser",
      "name": "Browser",
      "type": "browser",
      "state": { "wrapServices": false, "minimized": false }
    },
    {
      "id": "chat-node",
      "name": "Node",
      "state": { "wrapServices": false, "minimized": false },
      "type": "rest",
      "url": "http://127.0.0.1:8080"
    }
  ],
  "services": {
    "chat-node": [
      {
        "uuid": "chat-peer-server-svc",
        "serviceId": "peer-server",
        "serviceName": "Peer Server",
        "state": {
          "bypass": false,
          "port": 9000,
          "path": "/",
          "emitEvents": true
        }
      },
      {
        "uuid": "chat-node-monitor-svc",
        "serviceId": "monitor",
        "serviceName": "Peer Events"
      }
    ],
    "chat-browser": [
      {
        "uuid": "chat-input-svc",
        "serviceId": "hookup.to/service/injector",
        "serviceName": "Message",
        "state": { "plainText": true }
      },
      {
        "uuid": "chat-peer-svc",
        "serviceId": "hookup.to/service/peer-socket",
        "serviceName": "Peer Socket",
        "state": {
          "mode": "Receive and Send",
          "extractIncomingData": true,
          "peerPort": 9000,
          "peerPath": "/",
          "peerHost": "HKP_RUNTIME_HOST"
        }
      },
      {
        "uuid": "chat-monitor-svc",
        "serviceId": "hookup.to/service/monitor",
        "serviceName": "Incoming Messages"
      },
      {
        "uuid": "chat-stopper-svc",
        "serviceId": "hookup.to/service/stopper",
        "serviceName": "Stopper"
      }
    ]
  }
}
