{
  "boardName": "Monitor Demo",
  "runtimes": [
    { "id": "ui", "name": "Browser", "type": "browser", "state": { "wrapServices": false } }
  ],
  "services": {
    "ui": [
      {
        "uuid": "timer-svc",
        "serviceId": "hookup.to/service/timer",
        "serviceName": "Timer",
        "state": { "periodic": true, "periodicValue": 800, "periodicUnit": "ms", "running": true, "start": true, "immediate": true }
      },
      {
        "uuid": "data-svc",
        "serviceId": "hookup.to/service/map",
        "serviceName": "Data",
        "state": {
          "template": {
            "tick=": "triggerCount",
            "value=": "round(rand() * 100)"
          }
        }
      },
      {
        "uuid": "monitor-svc",
        "serviceId": "hookup.to/service/monitor",
        "serviceName": "Monitor"
      },
      {
        "uuid": "display-svc",
        "serviceId": "hookup.to/service/map",
        "serviceName": "Display",
        "state": {
          "template": {
            "type": "text",
            "text=": "concat('tick=', params.tick, '  value=', params.value)",
            "y": "45%",
            "color": "#6366f1",
            "font": { "size": "8%", "family": "monospace" }
          }
        }
      },
      {
        "uuid": "canvas-svc",
        "serviceId": "hookup.to/service/canvas",
        "serviceName": "Canvas",
        "state": { "clearOnRedraw": true, "resizable": true, "size": [600, 400] }
      }
    ]
  }
}
