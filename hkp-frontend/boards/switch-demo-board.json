{
  "boardName": "Switch Demo",
  "runtimes": [
    {
      "id": "ui",
      "name": "Browser",
      "type": "browser",
      "state": {
        "wrapServices": false
      }
    }
  ],
  "services": {
    "ui": [
      {
        "uuid": "timer-svc",
        "serviceId": "hookup.to/service/timer",
        "serviceName": "Timer",
        "state": {
          "periodic": true,
          "periodicValue": 800,
          "periodicUnit": "ms",
          "running": true,
          "start": true,
          "immediate": true
        }
      },
      {
        "uuid": "data-svc",
        "serviceId": "hookup.to/service/map",
        "serviceName": "Data",
        "state": {
          "template": {
            "tick=": "triggerCount",
            "value=": "round(rand() * 100)"
          }
        }
      },
      {
        "uuid": "switch-svc",
        "serviceId": "hookup.to/service/switch",
        "serviceName": "Switch"
      },
      {
        "uuid": "monitor-svc",
        "serviceId": "hookup.to/service/monitor",
        "serviceName": "Monitor"
      }
    ]
  }
}
