{
  "boardName": "Group By Demo",
  "runtimes": [
    {
      "id": "ui",
      "name": "Browser",
      "type": "browser",
      "state": {
        "wrapServices": false
      }
    }
  ],
  "services": {
    "ui": [
      {
        "uuid": "timer-svc",
        "serviceId": "hookup.to/service/timer",
        "serviceName": "Timer",
        "state": {
          "periodic": true,
          "periodicValue": 1,
          "periodicUnit": "s",
          "running": true,
          "start": true,
          "immediate": true
        }
      },
      {
        "uuid": "data-svc",
        "serviceId": "hookup.to/service/map",
        "serviceName": "Sample Data",
        "state": {
          "template": {
            "=": "[{cat:'A'},{cat:'B'},{cat:'A'},{cat:'C'},{cat:'B'},{cat:'A'},{cat:'C'},{cat:'B'},{cat:'A'}]"
          }
        }
      },
      {
        "uuid": "groupby-svc",
        "serviceId": "hookup.to/service/group-by",
        "serviceName": "Group By",
        "state": {
          "property": "cat",
          "mode": "histogram"
        }
      },
      {
        "uuid": "monitor-svc",
        "serviceId": "hookup.to/service/monitor",
        "serviceName": "Monitor"
      }
    ]
  }
}
